{
  "name": "tankatus-is-backend",
  "version": "1.0.0",
  "description": "Backend API для ИС управления IT-проектами Танкатус",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "cd ../frontend && npm install && npx vite build",
    "prod": "npm run build && node src/index.js",
    "db:init": "node -e \"require('./src/db').initSchema(); console.log('DB initialized')\""
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
